# Google Earth Engine (for pipeline GEE exports)
# Option A: Service account JSON key (for CI/GitHub Actions)
GEE_SERVICE_ACCOUNT_KEY=/path/to/service-account.json
# Option B: OAuth credentials (for local development)
# Run: earthengine authenticate
EE_CLIENT_ID=
EE_CLIENT_SECRET=

# Cloudflare (for deployment and R2 uploads)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Google Cloud Storage (for raster downloads)
# Authenticate via: gcloud auth application-default login
# Or set: GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
